{
  "manifest_version": 3,
  "name": "Job Application Tracker v10",
  "short_name": "JAT v10",
  "version": "10.0.7",
  "description": "Captures job applications across every job board. Generic detector + atelier dashboard backed by a local SQLite desktop companion.",
  "permissions": ["storage", "downloads", "tabs", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:7744/*",
    "http://127.0.0.1:7744/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://*.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Job Application Tracker v10",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://localhost/*",
        "*://127.0.0.1/*",
        "*://*.google.com/*",
        "*://*.youtube.com/*",
        "*://*.gmail.com/*",
        "*://mail.google.com/*",
        "*://docs.google.com/*",
        "*://accounts.google.com/*",
        "*://github.com/*",
        "*://*.github.com/*",
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*"
      ],
      "js": ["content/loader.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/detector.js", "content/panel.js", "content/signals/*.js", "content/lib/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
