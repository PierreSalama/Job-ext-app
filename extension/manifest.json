{
  "manifest_version": 3,
  "name": "Job Application Tracker v10",
  "short_name": "JAT v10",
  "version": "10.0.6",
  "description": "Skeleton rebuild. Bare-bones MV3 extension + Electron companion app. Features added one at a time, tested before the next is started.",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "http://localhost:7744/*",
    "http://127.0.0.1:7744/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://*.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Job Application Tracker v10",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
