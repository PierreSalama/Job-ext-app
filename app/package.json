{
  "name": "jat9-app",
  "version": "9.0.0",
  "description": "Desktop companion for the Job Application Tracker v9 Chrome extension. System tray, native notifications, global hotkey, real-time sync on :7733.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pierre.jat9",
    "productName": "Job Application Tracker",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icons/icon.ico"
    },
    "nsis": {
      "installerIcon": "src/icons/icon.ico",
      "uninstallerIcon": "src/icons/icon.ico",
      "installerHeaderIcon": "src/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Job Application Tracker"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icons/icon512.png",
      "category": "Office"
    },
    "publish": [{
      "provider": "github",
      "owner": "PierreSalama",
      "repo": "Job-ext-app",
      "releaseType": "release"
    }]
  },
  "author": "Pierre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PierreSalama/Job-ext-app.git"
  }
}
