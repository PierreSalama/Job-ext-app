{
  "name": "jat8-app",
  "version": "8.0.0",
  "description": "Desktop companion for the Job Application Tracker v8 Chrome extension. System tray, native notifications, global hotkey, real-time sync on :7733.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pierre.jat8",
    "productName": "Job Application Tracker",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "publish": null
  },
  "author": "Pierre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PierreSalama/Job-ext-app.git"
  }
}
