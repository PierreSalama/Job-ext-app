{
  "name": "jat10-app",
  "version": "10.0.4",
  "description": "Desktop companion for the Job Application Tracker v10 Chrome extension. Skeleton — exposes a single /health endpoint on http://localhost:7744 so the extension popup can see it.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "publish:win": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pierre.jat10",
    "productName": "Job Application Tracker v10",
    "files": ["src/**/*", "package.json"],
    "artifactName": "JAT-v10-${ext}",
    "win": {
      "target": "nsis",
      "icon": "src/icons/icon.ico",
      "artifactName": "JAT-v10-setup.${ext}"
    },
    "nsis": {
      "installerIcon": "src/icons/icon.ico",
      "uninstallerIcon": "src/icons/icon.ico",
      "installerHeaderIcon": "src/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Job Application Tracker v10"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icons/icon128.png",
      "category": "Office"
    },
    "publish": [{
      "provider": "github",
      "owner": "PierreSalama",
      "repo": "Job-ext-app",
      "releaseType": "release"
    }]
  },
  "author": "Pierre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PierreSalama/Job-ext-app.git"
  }
}
